# SubHub.store Configuration Template
# Duplicate this file as .env and fill in the actual credentials

# Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Telegram user ID of the Administrator (for notifications)
ADMIN_CHAT_ID=123456789

# Web Server host and port
HOST=0.0.0.0
PORT=3000

# Secret key used to sign JWT authentication tokens (generate a secure random one)
JWT_SECRET=change_me_in_production_to_a_long_random_hash

# JWT signature settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Initial credentials for the Admin panel (seeded on first boot)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin_secure_password_here

# Database path and upload directory for screenshots
DB_PATH=data/subhub.db
UPLOAD_DIR=uploads/screenshots

# Referral rules
REFERRAL_REWARD_UZS=3000
SUSPICIOUS_REFERRAL_THRESHOLD=10
SUSPICIOUS_REFERRAL_WINDOW_HOURS=1

# Warranty policy days
WARRANTY_DAYS=7
